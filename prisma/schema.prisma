generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String      @id @default(uuid())
  clerkId    String      @unique
  email      String      @unique
  name       String?
  imageUrl   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  feedbacks  Feedback[]
  interviews Interview[]

  @@index([clerkId])
}

model Interview {
  id                 String     @id @default(uuid())
  userId             String
  language           String
  difficulty         String
  duration           Int
  status             String
  problemTitle       String
  problemDescription String
  code               String
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime   @default(now())
  style              String     @default("standard")
  outOfFrameCount    Int        @default(0)
  tabSwitchCount     Int        @default(0)
  multiplePeopleCount Int       @default(0)
  errorLogs          ErrorLog[]
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           Message[]
  report             Report?

  @@index([userId])
}

model Message {
  id          String    @id @default(uuid())
  interviewId String
  role        String
  content     String
  createdAt   DateTime  @default(now())
  thinking    String?
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
}

model Report {
  id                    String    @id @default(uuid())
  interviewId           String    @unique
  overallScore          Int
  technicalScore        Int
  communicationScore    Int
  problemSolvingScore   Int
  optimizationScore     Int
  codeQualityScore      Int
  strengths             Json
  weaknesses            Json
  suggestions           Json
  summary               String
  createdAt             DateTime  @default(now())
  nextSteps             Json?
  transcriptAnnotations Json?
  isPublic              Boolean   @default(true)
  estimatedLevel        String?
  isSolved              Boolean   @default(false)
  spaceComplexity       String?
  timeComplexity        String?
  interview             Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ErrorLog {
  id          String    @id @default(uuid())
  interviewId String
  errorType   String
  message     String
  createdAt   DateTime  @default(now())
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model EventLog {
  id          String   @id @default(uuid())
  interviewId String?
  userId      String?
  eventType   String
  details     Json?
  createdAt   DateTime @default(now())

  @@index([interviewId])
  @@index([userId])
  @@index([eventType])
}
