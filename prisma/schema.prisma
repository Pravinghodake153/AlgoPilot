datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String      @id @default(uuid())
  clerkId   String      @unique
  email     String      @unique
  name      String?
  imageUrl  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  interviews Interview[]
  feedbacks  Feedback[]

  @@index([clerkId])
}

model Interview {
  id                 String      @id @default(uuid())
  userId             String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  language           String      // "cpp", "java", "python", "javascript", "go"
  difficulty         String      // "easy", "medium", "hard"
  style              String      @default("standard") // "standard", "product", "startup", "service"
  duration           Int         // in minutes (e.g. 10, 20)
  status             String      // "setup", "in_progress", "completed", "cancelled"
  problemTitle       String
  problemDescription String      @db.Text
  code               String      @db.Text
  tabSwitchCount     Int         @default(0)
  outOfFrameCount    Int         @default(0)
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime    @default(now())
  messages           Message[]
  report             Report?
  errorLogs          ErrorLog[]

  @@index([userId])
}

model Message {
  id          String    @id @default(uuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  role        String    // "assistant", "user", "system"
  thinking    String?   @db.Text
  content     String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([interviewId])
}

model Report {
  id                 String    @id @default(uuid())
  interviewId        String    @unique
  interview          Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  overallScore       Int
  technicalScore     Int
  communicationScore Int
  problemSolvingScore Int
  optimizationScore  Int
  codeQualityScore   Int
  strengths          Json      // String[] stored as JSON
  weaknesses         Json      // String[] stored as JSON
  suggestions        Json      // String[] stored as JSON
  summary            String    @db.Text
  nextSteps          Json?     // String[] stored as JSON
  transcriptAnnotations Json?  // Array of { messageIndex, tag, rationale }
  
  // Advanced Metrics
  timeComplexity     String?
  spaceComplexity    String?
  isSolved           Boolean   @default(false)
  estimatedLevel     String?

  isPublic           Boolean   @default(true)
  createdAt          DateTime  @default(now())
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}

model ErrorLog {
  id          String    @id @default(uuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  errorType   String    // e.g. "TIMEOUT"
  message     String    @db.Text
  createdAt   DateTime  @default(now())

  @@index([interviewId])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model EventLog {
  id          String   @id @default(uuid())
  interviewId String?  // Optional, since some events might not be tied to an interview
  userId      String?  // Optional, for anonymous tracking before login
  eventType   String   // e.g. "TAB_SWITCH", "CAMERA_OUT_OF_FRAME", "TALKING_DETECTED", "PAGE_LOAD"
  details     Json?    // Any extra contextual data
  createdAt   DateTime @default(now())

  @@index([interviewId])
  @@index([userId])
  @@index([eventType])
}
